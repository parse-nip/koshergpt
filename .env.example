# --- Browser (Vite) ---
# Defaults to same-origin /api/chat (Cloudflare Pages Function → OpenRouter).
# VITE_CHAT_API_URL=http://localhost:8788/api/chat
# Same value as Workers secret CHAT_API_KEY when you enforce auth:
# VITE_CHAT_API_KEY=

# --- Cloudflare (Pages project → Secrets / Wrangler; never commit real keys) ---
# wrangler secret put OPENROUTER_API_KEY
# wrangler secret put CHAT_API_KEY   # optional; must match VITE_CHAT_API_KEY
# Optional OPENROUTER_MODEL (default in code / wrangler: google/gemini-2.5-flash)
